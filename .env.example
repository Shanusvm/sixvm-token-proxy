# Add your keys at http://localhost:8787/setup (recommended) — or paste them here.
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
OPENAI_API_KEY=
GEMINI_API_KEY=
# Optional: your OWN Supabase project for cloud usage storage (see /setup for
# the guided version). Without these, usage logs to a local file automatically.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
PORT=8787
# Security: the proxy only accepts connections from THIS machine by default.
# Set HOST=0.0.0.0 to allow agents on other machines (then use a firewall/VPN).
HOST=127.0.0.1
